# NemoClaw LaunchAgent secrets — EXAMPLE. Copy to ~/.nemoclaw/launchagent.env
# (or set NEMOCLAW_LAUNCHAGENT_ENV) and fill in real values. chmod 600 it.
# Consumed by scripts/install-launchagent.sh to resolve __KEY__ placeholders.
# The real file is gitignored; this example holds placeholders only.

# Telegram bot token for the bridge + health-check alerts (BotFather).
TELEGRAM_BOT_TOKEN=000000000:replace-with-your-bot-token

# Telegram chat ID allowed to talk to the bridge / receive briefings.
TELEGRAM_CHAT_ID=000000000

# NVIDIA API key used by the bridge's inference path.
NVIDIA_API_KEY=nvapi-replace-with-your-key
